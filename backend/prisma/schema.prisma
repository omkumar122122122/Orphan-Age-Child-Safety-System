  relatedPersonName String?
  relationship      String

  notes         String?
  isConfirmed   Boolean @default(false)
  confirmedById String?
  confirmedBy   User?   @relation("RelationshipConfirmedBy", fields: [confirmedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([childId])
  @@index([relatedChildId])
  @@map("child_relationships")
}

model AdoptionRecord {
  id      String @id @default(uuid())
