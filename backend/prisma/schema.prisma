// ============================================================
// Prisma Schema — Orphan Age Child Safety System
// Production-Ready v2 — Full Audit Fix Applied
// ============================================================
// CHANGES FROM v1:
//   FIX-1:  VisitRequest reviewedById/visitSupervisorId back-relations added to User
//   FIX-2:  SocialWorkerProfile.supervisorId wired as proper self-referencing @relation
//   FIX-3:  AIRiskScore.alertId wired to Alert with proper @relation + back-ref on Alert
//   FIX-4:  CaseAssignment @@unique replaced with @@index; partial unique enforced via raw SQL
//   FIX-5:  BiometricData @@unique([childId,type,isActive]) replaced; partial unique via raw SQL
//   FIX-6:  AttendanceRecord.date changed to @db.Date to fix @@unique scope
//   FIX-7:  AttendanceRecord.verifiedBy String? → verifiedById FK to User
//   FIX-8:  ChildRelationship.confirmedById wired as proper FK to User
//   FIX-9:  AIRiskScore.computedBy String → isComputedBySystem Boolean + computedById FK
//   FIX-10: MedicalHistory.medications/allergies String? → Json?
//   FIX-11: AIConversationMessage.role String → MessageRole enum
//   FIX-12: WelfareSession.aiSessionId optional FK to AISession added
//   FIX-13: Child.parentsMaritalStatus String? → MaritalStatus?
//   FIX-14: Parent.gender / FamilyMember.gender String? → Gender enum
//   FIX-15: HealthReport.reportedBy clarified as free-text display field (comment)
//   FIX-16: Redundant indexes removed: User@@index([email]), RefreshToken@@index([token/jti])
//   FIX-17: Added missing composite indexes throughout
//   FIX-18: OtpToken @@index([userId, purpose]) added
//   NOTE:   Partial unique indexes for BiometricData and CaseAssignment must be added
//           manually in the migration SQL (Prisma does not support partial indexes natively):
//             CREATE UNIQUE INDEX biometric_data_active_unique
//               ON biometric_data(child_id, type) WHERE is_active = true;
//             CREATE UNIQUE INDEX case_assignment_active_unique
//               ON case_assignments(social_worker_profile_id, child_id) WHERE status = 'ACTIVE';
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

