  conditionName      String
  severity           MedicalConditionSeverity @default(MILD)
  diagnosedDate      DateTime?
  diagnosedBy        String?
  diagnosedAt        String?
  isCurrent          Boolean                  @default(true)
  isChronicCondition Boolean                  @default(false)
  treatmentDetails   String?
  medications        String?
  allergies          String?
  resolvedDate       DateTime?
  notes              String?

  recordedById String?
  recordedBy   User?   @relation("MedHistoryRecordedBy", fields: [recordedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([childId])
  @@index([isCurrent])
  @@index([severity])
  @@map("medical_histories")
}

model HealthReport {
  id      String @id @default(uuid())
  childId String
  child   Child  @relation(fields: [childId], references: [id], onDelete: Cascade)

