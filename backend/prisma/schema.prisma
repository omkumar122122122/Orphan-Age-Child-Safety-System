  childId String
  child   Child  @relation(fields: [childId], references: [id], onDelete: Cascade)

  guardianName  String
  relation      GuardianRelation
  contactPhone  String?
  contactEmail  String?
  address       String?
  aadhaarNumber String?
  isCurrent     Boolean          @default(false)

  startDate       DateTime
  endDate         DateTime?
  reasonForChange String?
  handoverNotes   String?

  linkedParentId String?
  linkedParent   Parent? @relation("LinkedParent", fields: [linkedParentId], references: [id], onDelete: SetNull)

  courtOrderNumber String?
  courtOrderDate   DateTime?
  courtOrderUrl    String?

  recordedById String?
  recordedBy   User?   @relation("GuardianRecordedBy", fields: [recordedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([childId])
  @@index([isCurrent])
  @@index([linkedParentId])
  @@map("guardian_histories")
}

model BiometricData {
  id      String @id @default(uuid())
  childId String
  child   Child  @relation(fields: [childId], references: [id], onDelete: Cascade)

  type       BiometricType
  capturedAt DateTime      @default(now())

  capturedBy     String?
  capturedByUser User?   @relation("BiometricCapturedBy", fields: [capturedBy], references: [id], onDelete: SetNull)

  faceEncodingJson String? @db.Text
  faceImageUrl     String?
  faceModelVersion String?

  fingerprintTemplate String? @db.Text
  fingerprintFinger   String?

  templateData String? @db.Text
  deviceId     String?
  quality      Float?
  isActive     Boolean @default(true)
  notes        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([childId])
  @@index([type])
  @@index([isActive])
  @@map("biometric_data")
}

model ChildDocument {
  id      String @id @default(uuid())
  childId String
  child   Child  @relation(fields: [childId], references: [id], onDelete: Cascade)

  documentType ChildDocumentType
  title        String
  fileName     String
  originalName String
  mimeType     String
  fileSize     Int
  storagePath  String
  storageUrl   String?

  documentNumber String?
  issuedBy       String?
  issuedDate     DateTime?
  expiryDate     DateTime?
  isVerified     Boolean   @default(false)

  verifiedById    String?
  verifiedBy      User?     @relation("ChildDocumentVerifiedBy", fields: [verifiedById], references: [id], onDelete: SetNull)
  verifiedAt      DateTime?
  rejectionReason String?
  notes           String?

  uploadedById String?
  uploadedBy   User?   @relation("ChildDocumentUploadedBy", fields: [uploadedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([childId])
  @@index([documentType])
  @@map("child_documents")
}

model ChildRelationship {
