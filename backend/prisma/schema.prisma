  @@index([severity])
  @@index([type])
  @@index([status])
  @@index([childId])
  @@index([orphanageId])
  @@index([createdAt])
  @@index([status, severity])
  @@index([childId, status])
  @@map("alerts")
}

model AISession {
  id                String                  @id @default(uuid())
  sessionType       AISessionType
  status            AISessionStatus         @default(SCHEDULED)
  provider          AIProvider              @default(OPENAI_GPT4)
  childId           String?
  initiatedById     String?
  scheduledAt       DateTime?
  startedAt         DateTime?
  completedAt       DateTime?
  cancelledAt       DateTime?
  failureReason     String?
  totalTokensUsed   Int?
  estimatedCostUsd  Float?
  summary           String?
  riskLevelDetected RiskLevel?
  confidenceScore   Float?
  modelVersion      String?
  sessionConfig     Json?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  messages          AIConversationMessage[]
  child             Child?                  @relation(fields: [childId], references: [id])
  initiatedBy       User?                   @relation("AISessionUser", fields: [initiatedById], references: [id])
  welfareSessions   WelfareSession[]

  @@index([childId])
  @@index([initiatedById])
  @@index([sessionType])
  @@index([status])
  @@index([scheduledAt])
  @@map("ai_sessions")
}

model AIConversationMessage {
  id               String      @id @default(uuid())
  sessionId        String
  role             MessageRole
  content          String
  sequence         Int
  promptTokens     Int?
  completionTokens Int?
  sentimentScore   Float?
  detectedTopics   Json?
  flaggedContent   Boolean     @default(false)
  flagReason       String?
  createdAt        DateTime    @default(now())
  session          AISession   @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, sequence])
  @@index([sessionId])
  @@map("ai_conversation_messages")
}

model AIRiskScore {
  id                 String    @id @default(uuid())
  childId            String
  riskLevel          RiskLevel
  score              Int
  attendanceScore    Int?
  healthScore        Int?
  welfareScore       Int?
  guardianScore      Int?
  adoptionScore      Int?
  computedAt         DateTime  @default(now())
  isComputedBySystem Boolean   @default(true)
  computedById       String?
  modelVersion       String?
  notes              String?
  alertTriggered     Boolean   @default(false)
  alertId            String?
  alert              Alert?    @relation(fields: [alertId], references: [id])
  child              Child     @relation(fields: [childId], references: [id], onDelete: Cascade)
  computedBy         User?     @relation("RiskScoreComputedBy", fields: [computedById], references: [id])

  @@index([childId])
  @@index([riskLevel])
  @@index([computedAt])
  @@index([childId, computedAt])
  @@index([riskLevel, computedAt])
  @@map("ai_risk_scores")
}

