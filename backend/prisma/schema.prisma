// ═══════════════════════════════════════════════════════════
// ── SECTION 10: USER MODEL
// ═══════════════════════════════════════════════════════════

model User {
  id    String  @id @default(uuid())
  email String  @unique
  phone String? @unique

  // Auth
  password       String?
  provider       AuthProvider @default(LOCAL)
  providerUserId String?

  // Profile
  firstName String
  lastName  String
  avatar    String?
  role      Role    @default(GUEST)

  // Account status
  isActive           Boolean @default(true)
  isEmailVerified    Boolean @default(false)
  isPhoneVerified    Boolean @default(false)
  isTwoFactorEnabled Boolean @default(false)
  twoFactorSecret    String? // AES-256 encrypted at service layer

  // Email verification
  emailVerificationToken       String?   @unique
  emailVerificationTokenExpiry DateTime?

  // Password reset
  passwordResetToken       String?   @unique
  passwordResetTokenExpiry DateTime?

  // Security tracking
  loginAttempts     Int       @default(0)
  lockedUntil       DateTime?
  lastLoginAt       DateTime?
  lastLoginIp       String?
  passwordChangedAt DateTime?

  // Timestamps
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Relations
  refreshTokens          RefreshToken[]
  otpTokens              OtpToken[]
  parentProfile          Parent?
  socialWorkerProfile    SocialWorkerProfile?
  orphanageStaff         OrphanageStaff[]
  notifications          Notification[]
  auditLogs              AuditLog[]           @relation("UserAuditLogs")
  performedTrustLogs     TrustScoreLog[]      @relation("TrustScorePerformedBy")
  assignedChildren       Child[]              @relation("AssignedSocialWorker")
  caseworkerChildren     Child[]              @relation("AssignedCaseworker")
  verifiedParents        Parent[]             @relation("VerifiedBy")
  createdAlerts          Alert[]              @relation("AlertCreatedBy")
  resolvedAlerts         Alert[]              @relation("AlertResolvedBy")
  reviewedDocuments      ParentDocument[]     @relation("DocumentReviewedBy")
  verifiedChildDocs      ChildDocument[]      @relation("ChildDocumentVerifiedBy")
  uploadedChildDocs      ChildDocument[]      @relation("ChildDocumentUploadedBy")
  markedAttendance       AttendanceRecord[]   @relation("AttendanceMarkedBy")
  // FIX-7: back-relation for verifiedById on AttendanceRecord
  verifiedAttendance     AttendanceRecord[]   @relation("AttendanceVerifiedBy")
  recordedMedHistory     MedicalHistory[]     @relation("MedHistoryRecordedBy")
  recordedHealthReps     HealthReport[]       @relation("HealthReportRecordedBy")
  recordedEducation      EducationRecord[]    @relation("EducationRecordedBy")
  recordedGuardians      GuardianHistory[]    @relation("GuardianRecordedBy")
  capturedBiometrics     BiometricData[]      @relation("BiometricCapturedBy")
  reviewedAdoptions      AdoptionRecord[]     @relation("AdoptionReviewedBy")
  conductedSessions      WelfareSession[]     @relation("SessionConductedBy")
  aiSessionsUser         AISession[]          @relation("AISessionUser")
  reportRequests         ReportExport[]       @relation("ReportRequestedBy")
  systemSettings         SystemSetting[]      @relation("SettingUpdatedBy")
  initiatedPoliceVer     PoliceVerification[] @relation("PoliceVerInitiatedBy")
  reviewedPoliceVer      PoliceVerification[] @relation("PoliceVerReviewedBy")
  // FIX-1: back-relations for VisitRequest reviewer and supervisor
  reviewedVisitRequests  VisitRequest[]       @relation("VisitRequestReviewedBy")
  supervisedVisits       VisitRequest[]       @relation("VisitRequestSupervisor")
  // FIX-8: back-relation for ChildRelationship.confirmedById
  confirmedRelationships ChildRelationship[]  @relation("RelationshipConfirmedBy")
  // FIX-9: back-relation for AIRiskScore.computedById
  computedRiskScores     AIRiskScore[]        @relation("RiskScoreComputedBy")

  // FIX-16: @@index([email]) removed — @unique already creates a unique index in PostgreSQL
  @@index([role])
  @@index([isActive])
  @@index([deletedAt])
  @@map("users")
}

// ─────────────────────────────────────────────
// Refresh Token
// ─────────────────────────────────────────────

model RefreshToken {
  id    String @id @default(uuid())
  token String @unique // bcrypt-hashed
  jti   String @unique // JWT ID — token family tracking

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  userAgent String?
  ipAddress String?
  deviceId  String?

  isRevoked     Boolean   @default(false)
  revokedAt     DateTime?
  revokedReason String? // LOGOUT | ROTATION | SECURITY | EXPIRED

  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  // FIX-17: composite for "get valid tokens for a user"
  @@index([userId, isRevoked])
  @@index([isRevoked])
  @@index([expiresAt]) // cleanup cron
  // FIX-16: @@index([token]) and @@index([jti]) removed — both are @unique
  @@map("refresh_tokens")
}

// ─────────────────────────────────────────────
// OTP Token
// ─────────────────────────────────────────────

model OtpToken {
  id      String     @id @default(uuid())
  code    String // bcrypt-hashed OTP
  purpose OtpPurpose

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  deliveredTo  String // email or phone
  deliveryType String @default("email")

  attempts    Int       @default(0)
  maxAttempts Int       @default(5)
  isUsed      Boolean   @default(false)
  usedAt      DateTime?

  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([purpose])
  @@index([isUsed])
  @@index([expiresAt]) // cleanup cron
  // FIX-17/FIX-18: composite for "find active OTP for user+purpose" — most common lookup
  @@index([userId, purpose])
  @@index([userId, purpose, isUsed])
  @@map("otp_tokens")
}

// ─────────────────────────────────────────────
// Audit Log
// NOTE: userId nullable intentionally — pre-auth events (failed logins,
//       unknown IPs) must be logged. SetNull preserves history on user deletion.
// ─────────────────────────────────────────────

model AuditLog {
  id     String  @id @default(uuid())
  userId String?
  user   User?   @relation("UserAuditLogs", fields: [userId], references: [id], onDelete: SetNull)

  action     String
  resource   String?
  resourceId String?
  details    Json?
  ipAddress  String?
  userAgent  String?
  success    Boolean @default(true)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@index([resourceId])
  @@index([success])
  @@index([userId, createdAt])
  @@map("audit_logs")
}

// ═══════════════════════════════════════════════════════════
// ── SECTION 11: ORPHANAGE MODELS
// ═══════════════════════════════════════════════════════════

model Orphanage {
  id   String @id @default(uuid())
  code String @unique // e.g. "ORP-DL-2012-001"

  name                    String
  organizationType        OrganizationType
  status                  OrphanageStatus  @default(ACTIVE)
  registrationNumber      String           @unique
  governmentLicenseNumber String?          @unique
  establishmentDate       DateTime?

  // Contact
  officialEmail    String  @unique
  phone            String
  alternativePhone String?
  website          String?

  // Address
  addressLine1 String
  addressLine2 String?
  landmark     String?
  city         String
  district     String?
  state        String
  pincode      String
  country      String  @default("India")
  latitude     Float?
  longitude    Float?

  // Capacity
  totalCapacity    Int @default(0)
  currentOccupancy Int @default(0)

  // AI Safety config
  faceRecognitionEnabled     Boolean @default(false)
  cctvInstalled              Boolean @default(false)
  numberOfCameras            Int     @default(0)
  gpsTrackingAvailable       Boolean @default(false)
  emergencyAlertEnabled      Boolean @default(false)
  biometricAttendanceEnabled Boolean @default(false)

  // Bank details (encrypted at service layer)
  bankName          String?
  bankAccountNumber String? // AES-256 encrypted
  bankIfscCode      String?
  bankAccountHolder String?

  // Compliance
  complianceScore    Int       @default(0) // 0–100
  lastInspectionDate DateTime?
  nextInspectionDue  DateTime?

  // Flags
  isActive   Boolean @default(true)
  isVerified Boolean @default(false)
  isFeatured Boolean @default(false)

  // GST / PAN (encrypted at service layer)
  gstNumber String? // AES-256 encrypted
  panNumber String? // AES-256 encrypted

  // Emergency Contact (FIX-1: Store emergency contact data)
  emergencyContactPerson       String?
  emergencyContactMobile       String?
  emergencyContactEmail        String?
  emergencyContactRelationship String?

  // Facilities (FIX-2: Store facilities as JSON array)
  facilities Json? // Array of facility names

  // Timestamps
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Relations
  staff         OrphanageStaff[]
  licenses      OrphanageLicense[]
  children      Child[]
  visitRequests VisitRequest[]
  alerts        Alert[]            @relation("OrphanageAlerts")

  @@index([status])
  @@index([state])
  @@index([city])
  @@index([isActive])
  @@index([isVerified])
  @@map("orphanages")
}

// ─────────────────────────────────────────────
// Orphanage Staff (User ↔ Orphanage join)
// NOTE: @@unique([orphanageId, userId]) enforces one record per user per orphanage.
//       If a user can hold multiple roles at the same orphanage, relax this to
//       @@unique([orphanageId, userId, role]) after team review.
// ─────────────────────────────────────────────

model OrphanageStaff {
  id          String    @id @default(uuid())
  orphanageId String
  orphanage   Orphanage @relation(fields: [orphanageId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  role        OrphanageStaffRole @default(OTHER)
  designation String?
  employeeId  String?
  joiningDate DateTime?
  endDate     DateTime?
  isActive    Boolean            @default(true)
  notes       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([orphanageId, userId])
  @@index([orphanageId])
  @@index([userId])
  @@index([isActive])
  @@map("orphanage_staff")
}

// ─────────────────────────────────────────────
// Orphanage License
// ─────────────────────────────────────────────

model OrphanageLicense {
  id          String    @id @default(uuid())
  orphanageId String
  orphanage   Orphanage @relation(fields: [orphanageId], references: [id], onDelete: Cascade)

  licenseType      LicenseType
  licenseNumber    String
  issuingAuthority String
  status           LicenseStatus @default(PENDING)

  issuedDate  DateTime?
  expiryDate  DateTime?
  renewedDate DateTime?

  documentUrl String?
  storagePath String?
  notes       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([orphanageId, licenseType])
  @@index([orphanageId])
  @@index([status])
  @@index([expiryDate]) // expiry alert cron
  @@map("orphanage_licenses")
}

// ═══════════════════════════════════════════════════════════
// ── SECTION 12: PARENT MODELS
// ═══════════════════════════════════════════════════════════

model Parent {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Personal
  dateOfBirth       DateTime?
  // FIX-14: was String? — now proper Gender enum
  gender            Gender?
  nationality       String         @default("Indian")
  religion          String?
  maritalStatus     MaritalStatus?
  spouseName        String?
  spouseDateOfBirth DateTime?
  spouseOccupation  String?

  // Contact
  alternatePhone           String?
  emergencyContact         String?
  emergencyContactName     String?
  emergencyContactRelation String?

  // Occupation & Income
  occupation        String?
  employmentType    EmploymentType?
  employerName      String?
  employerAddress   String?
  workPhone         String?
  yearsOfExperience Int?
  annualIncome      Float?
  incomeRange       IncomeRange?
  incomeVerified    Boolean         @default(false)

  // Housing
  houseOwnership HouseOwnership?
  numberOfRooms  Int?
  hasChildRoom   Boolean         @default(false)

  // Health
  hasChronicIllness     Boolean @default(false)
  chronicIllnessDetails String?
  hasDisability         Boolean @default(false)
  disabilityDetails     String?
  hasHealthInsurance    Boolean @default(false)

  // Adoption Preferences
  preferredChildAge   String?
  preferredGender     GenderPreference?
  preferredCount      Int               @default(1)
  openToSpecialNeeds  Boolean           @default(false)
  specialNeedsDetails String?
  adoptionMotivation  String?

  // Verification
  verificationStatus ParentVerificationStatus @default(PENDING)
  verificationNotes  String?
  verifiedById       String?
  verifiedBy         User?                    @relation("VerifiedBy", fields: [verifiedById], references: [id], onDelete: SetNull)
  verifiedAt         DateTime?
  rejectionReason    String?
  interviewDate      DateTime?
  interviewNotes     String?
  interviewPassedAt  DateTime?

  // Trust Score
  trustScore           Int       @default(0) // service enforces 0–100
  trustScoreBreakdown  Json?
  lastTrustScoreUpdate DateTime?

  // KYC
  kycStatus          KycStatus @default(PENDING)
  kycSubmittedAt     DateTime?
  kycApprovedAt      DateTime?
  kycRejectionReason String?

  // Flags
  isProfileComplete       Boolean @default(false)
  isActive                Boolean @default(true)
  hasAdoptedBefore        Boolean @default(false)
  previousAdoptionDetails String?
  isFeatured              Boolean @default(false)

  // Timestamps
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Relations
  addresses          ParentAddress[]
  documents          ParentDocument[]
  familyMembers      FamilyMember[]
  references         ParentReference[]
  policeVerification PoliceVerification?
  trustScoreLogs     TrustScoreLog[]
  adoptionRecords    AdoptionRecord[]
  visitRequests      VisitRequest[]
  guardianHistories  GuardianHistory[]   @relation("LinkedParent")
  caseAssignments    CaseAssignment[]
  alerts             Alert[]             @relation("ParentAlerts")

  @@index([userId])
  @@index([verificationStatus])
  @@index([trustScore])
  @@index([kycStatus])
  @@index([isActive])
  @@index([deletedAt])
  @@map("parents")
}

// ─────────────────────────────────────────────
// Parent Reference
// ─────────────────────────────────────────────

model ParentReference {
  id       String @id @default(uuid())
  parentId String
  parent   Parent @relation(fields: [parentId], references: [id], onDelete: Cascade)

  name       String
  phone      String
  relation   String
  email      String?
  occupation String?
  isVerified Boolean   @default(false)
  verifiedAt DateTime?
  notes      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([parentId])
  @@map("parent_references")
}

// ─────────────────────────────────────────────
// Parent Address
// ─────────────────────────────────────────────

model ParentAddress {
  id       String @id @default(uuid())
  parentId String
  parent   Parent @relation(fields: [parentId], references: [id], onDelete: Cascade)

  type         AddressType @default(CURRENT)
  addressLine1 String
  addressLine2 String?
  landmark     String?
  city         String
  district     String?
  state        String
  pincode      String
  country      String      @default("India")

  isVerified Boolean   @default(false)
  verifiedAt DateTime?
  isPrimary  Boolean   @default(false)
  latitude   Float?
  longitude  Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([parentId])
  @@index([type])
  @@index([isPrimary])
  @@map("parent_addresses")
}

// ─────────────────────────────────────────────
// Family Member
// ─────────────────────────────────────────────

model FamilyMember {
  id       String @id @default(uuid())
  parentId String
  parent   Parent @relation(fields: [parentId], references: [id], onDelete: Cascade)

  name          String
  relationship  RelationshipType
  dateOfBirth   DateTime?
  // FIX-14: was String? — now proper Gender enum
  gender        Gender?
  occupation    String?
  annualIncome  Float?
  isDependent   Boolean          @default(false)
  contactPhone  String?
  // encrypted at service layer
  aadhaarNumber String?
  notes         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([parentId])
  @@map("family_members")
}

// ─────────────────────────────────────────────
// Parent Document
// ─────────────────────────────────────────────

model ParentDocument {
  id       String @id @default(uuid())
  parentId String
  parent   Parent @relation(fields: [parentId], references: [id], onDelete: Cascade)

  documentType DocumentType
  status       DocumentStatus @default(UPLOADED)

  fileName     String
  originalName String
  mimeType     String
  fileSize     Int
  storagePath  String
  storageUrl   String?

  // encrypted at service layer
  documentNumber String?
  issuedBy       String?
  issuedDate     DateTime?
  expiryDate     DateTime?

  reviewedById    String?
  reviewedBy      User?     @relation("DocumentReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewedAt      DateTime?
  rejectionReason String?
  reviewNotes     String?
  isRequired      Boolean   @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([parentId])
  @@index([documentType])
  @@index([status])
  @@index([expiryDate]) // expiry alert cron
  @@map("parent_documents")
}

// ─────────────────────────────────────────────
// Police Verification
// ─────────────────────────────────────────────

model PoliceVerification {
  id       String @id @default(uuid())
  parentId String @unique
  parent   Parent @relation(fields: [parentId], references: [id], onDelete: Cascade)

  status            PoliceVerificationStatus @default(NOT_INITIATED)
  // @unique but nullable — PostgreSQL allows multiple NULLs on a unique column
  applicationNumber String?                  @unique

  appliedAt      DateTime?
  appliedStation String?
  stationAddress String?

  officerName        String?
  officerBadgeNumber String?
  officerPhone       String?

  clearedAt         DateTime?
  certificateNumber String?
  certificateUrl    String?
  validUntil        DateTime?

  flagReason         String?
  flagDetails        String?
  crimeRecordFound   Boolean @default(false)
  crimeRecordDetails String?

  initiatedById String?
  initiatedBy   User?   @relation("PoliceVerInitiatedBy", fields: [initiatedById], references: [id], onDelete: SetNull)
  reviewedById  String?
  reviewedBy    User?   @relation("PoliceVerReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)

  reviewNotes    String?
  lastFollowUpAt DateTime?
  nextFollowUpAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([parentId])
  @@index([status])
  @@index([nextFollowUpAt]) // follow-up scheduler cron
  @@map("police_verifications")
}

// ─────────────────────────────────────────────
// Trust Score Log
// ─────────────────────────────────────────────

model TrustScoreLog {
  id       String @id @default(uuid())
  parentId String
  parent   Parent @relation(fields: [parentId], references: [id], onDelete: Cascade)

  event         TrustScoreEvent
  previousScore Int
  newScore      Int
  delta         Int
  reason        String?

  performedById String?
  performedBy   User?   @relation("TrustScorePerformedBy", fields: [performedById], references: [id], onDelete: SetNull)
  metadata      Json?

  createdAt DateTime @default(now())

  @@index([parentId])
  @@index([event])
  @@index([createdAt])
  // FIX-17: composite for score history timeline
  @@index([parentId, createdAt])
  @@map("trust_score_logs")
}

// ═══════════════════════════════════════════════════════════
// ── SECTION 13: CHILD MODELS
// ═══════════════════════════════════════════════════════════

model Child {
  id        String @id @default(uuid())
  childCode String @unique // CHD-2024-001234 — auto-generated at service layer

  orphanageId String?
  orphanage   Orphanage? @relation(fields: [orphanageId], references: [id], onDelete: SetNull)

  // Personal
  firstName      String
  lastName       String?
  dateOfBirth    DateTime?
  approximateAge Int?
  gender         ChildGender @default(UNKNOWN)
  nationality    String      @default("Indian")
  religion       String?
  motherTongue   String?
  caste          String?

  // Physical
  height              Float?
  weight              Float?
  bloodGroup          BloodGroup @default(UNKNOWN)
  skinTone            String?
  eyeColor            String?
  hairColor           String?
  distinguishingMarks String?

  // Identity — encrypted at service layer
  aadhaarNumber   String?
  birthCertNumber String?
  photo           String?

  // Health overview
  healthStatus            HealthStatus @default(UNKNOWN)
  hasDisability           Boolean      @default(false)
  disabilityDetails       String?
  hasChronicCondition     Boolean      @default(false)
  chronicConditionDetails String?
  isVaccinationComplete   Boolean      @default(false)

  // Status
  currentStatus  ChildStatus    @default(REGISTERED)
  adoptionStatus AdoptionStatus @default(NOT_INITIATED)
  isAdoptable    Boolean        @default(false)
  isActive       Boolean        @default(true)

  // Entry
  admissionDate   DateTime @default(now())
  admissionReason String?
  entrySource     String?
  referredBy      String?

  // Family background
  fatherName           String?
  fatherStatus         ParentStatus?
  motherName           String?
  motherStatus         ParentStatus?
  // FIX-13: was String? — now proper MaritalStatus enum
  parentsMaritalStatus MaritalStatus?
  familyBackground     String?

  // Location found
  foundLocation String?
  foundDistrict String?
  foundState    String?

  assignedSocialWorkerId String?
  assignedSocialWorker   User?   @relation("AssignedSocialWorker", fields: [assignedSocialWorkerId], references: [id], onDelete: SetNull)
  assignedCaseworkerId   String?
  assignedCaseworker     User?   @relation("AssignedCaseworker", fields: [assignedCaseworkerId], references: [id], onDelete: SetNull)

  specialNotes  String?
  internalNotes String?

  // Timestamps
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Relations
  medicalHistories       MedicalHistory[]
  healthReports          HealthReport[]
  attendanceRecords      AttendanceRecord[]
  educationRecords       EducationRecord[]
  guardianHistories      GuardianHistory[]
  biometricData          BiometricData[]
  documents              ChildDocument[]
  relationships          ChildRelationship[] @relation("ChildRelationships")
  relatedInRelationships ChildRelationship[] @relation("RelatedChild")
  adoptionRecord         AdoptionRecord?
  visitRequests          VisitRequest[]
  welfareSessions        WelfareSession[]
  aiRiskScores           AIRiskScore[]
  aiSessions             AISession[]
  caseAssignments        CaseAssignment[]
  alerts                 Alert[]             @relation("ChildAlerts")

  @@index([childCode])
  @@index([orphanageId])
  @@index([currentStatus])
  @@index([adoptionStatus])
  @@index([healthStatus])
  @@index([isActive])
  @@index([isAdoptable])
  @@index([deletedAt])
  @@index([admissionDate])
  // FIX-17: FK fields on Child need explicit indexes for join performance
  @@index([assignedSocialWorkerId])
  @@index([assignedCaseworkerId])
  // Composite — bulk queries scoped to orphanage
  @@index([orphanageId, isActive])
  @@index([orphanageId, currentStatus])
  @@map("children")
}

// ═══════════════════════════════════════════════════════════
// ── SECTION 14: CHILD SUB-MODELS
// ═══════════════════════════════════════════════════════════

model MedicalHistory {
  id      String @id @default(uuid())
  childId String
