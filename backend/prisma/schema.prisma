  @@index([reportDate])
  @@index([healthStatus])
  @@map("health_reports")
}

model AttendanceRecord {
  id      String @id @default(uuid())
  childId String
  child   Child  @relation(fields: [childId], references: [id], onDelete: Cascade)

  date         DateTime
  status       AttendanceStatus @default(PRESENT)
  checkInTime  DateTime?
  checkOutTime DateTime?
