  child   Child  @relation(fields: [childId], references: [id], onDelete: Cascade)

  status AdoptionStatus @default(NOT_INITIATED)

  adoptiveParentId String?
  adoptiveParent   Parent? @relation(fields: [adoptiveParentId], references: [id], onDelete: SetNull)

  eligibilityDate    DateTime?
  matchedDate        DateTime?
  legalProcessStart  DateTime?
  completedDate      DateTime?
  cancelledDate      DateTime?
  cancellationReason String?

  courtName       String?
  courtCaseNumber String?
  courtOrderDate  DateTime?
  courtOrderUrl   String?

  adoptionCertNumber String?
  adoptionCertUrl    String?

  postAdoptionFollowUp1 DateTime?
  postAdoptionFollowUp2 DateTime?
  postAdoptionNotes     String?

  caraReferenceNumber String?
  caraStatus          String?

  reviewedById String?
  reviewedBy   User?   @relation("AdoptionReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewNotes  String?

  documents AdoptionDocument[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([adoptiveParentId])
  @@index([completedDate])
  @@map("adoption_records")
}

model AdoptionDocument {
  id String @id @default(uuid())

  adoptionRecordId String
