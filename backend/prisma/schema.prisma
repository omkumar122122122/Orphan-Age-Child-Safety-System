  documentType String
  fileName String
  originalName String
  mimeType String
  fileSize Int
  storagePath String
  storageUrl String?
  isVerified Boolean @default(false)
  verifiedById String?
  verifiedAt DateTime?

  uploadedById String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([adoptionRecordId, documentType])
  @@index([adoptionRecordId])
  @@map("adoption_documents")
}

// ═══════════════════════════════════════════════════════════
// ── SECTION 15: SOCIAL WORKER & CASE MANAGEMENT
// ═══════════════════════════════════════════════════════════

model SocialWorkerProfile {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  employeeId   String?               @unique
  designation  String?
  department   String?
  supervisorId String?
  supervisor   SocialWorkerProfile?  @relation("SWPSupervisor", fields: [supervisorId], references: [id], onDelete: SetNull)
  subordinates SocialWorkerProfile[] @relation("SWPSupervisor")

  qualification     String?
  specialization    String?
  yearsOfExperience Int?
  licenseNumber     String?
  licenseExpiry     DateTime?

  maxCaseLoad Int     @default(20)
  isActive    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  caseAssignments CaseAssignment[]

  @@index([userId])
  @@index([isActive])
  @@index([supervisorId])
  @@map("social_worker_profiles")
}

model CaseAssignment {
  id String @id @default(uuid())

  socialWorkerProfileId String
  socialWorker          SocialWorkerProfile @relation(fields: [socialWorkerProfileId], references: [id], onDelete: Cascade)

  childId String?
  child   Child?  @relation(fields: [childId], references: [id], onDelete: SetNull)

  parentId String?
  parent   Parent? @relation(fields: [parentId], references: [id], onDelete: SetNull)

  status     CaseAssignmentStatus @default(ACTIVE)
  assignedAt DateTime             @default(now())
  closedAt   DateTime?
  notes      String?
  priority   Int                  @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([socialWorkerProfileId])
  @@index([childId])
  @@index([parentId])
  @@index([status])
  @@index([socialWorkerProfileId, childId, status])
  @@map("case_assignments")
}

// ═══════════════════════════════════════════════════════════
// ── SECTION 16: VISIT REQUESTS & WELFARE SESSIONS
// ═══════════════════════════════════════════════════════════

model VisitRequest {
  id String @id @default(uuid())

  parentId String?
  parent   Parent? @relation(fields: [parentId], references: [id], onDelete: SetNull)

  childId String?
  child   Child?  @relation(fields: [childId], references: [id], onDelete: SetNull)

  orphanageId String?
  orphanage   Orphanage? @relation(fields: [orphanageId], references: [id], onDelete: SetNull)

  visitType VisitType          @default(REGULAR_VISIT)
  status    VisitRequestStatus @default(PENDING)

  requestedDate DateTime
  requestedTime String?
  confirmedDate DateTime?
  confirmedTime String?
  duration      Int?

  adoptionRecordId String?

  reviewedById    String?
  reviewedBy      User?   @relation("VisitRequestReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)
  approvalNotes   String?
  rejectionReason String?

  visitSupervisorId String?
  visitSupervisor   User?     @relation("VisitRequestSupervisor", fields: [visitSupervisorId], references: [id], onDelete: SetNull)
  visitNotes        String?
  completedAt       DateTime?
  noShowReason      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  welfareSessions WelfareSession[]

  @@index([parentId])
  @@index([childId])
  @@index([orphanageId])
  @@index([status])
  @@index([requestedDate])
  @@index([orphanageId, confirmedDate])
  @@index([parentId, status])
  @@map("visit_requests")
}

model WelfareSession {
  id      String @id @default(uuid())
  childId String
  child   Child  @relation(fields: [childId], references: [id], onDelete: Cascade)

  visitRequestId String?
  visitRequest   VisitRequest? @relation(fields: [visitRequestId], references: [id], onDelete: SetNull)

  conductedById String?
  conductedBy   User?   @relation("SessionConductedBy", fields: [conductedById], references: [id], onDelete: SetNull)

  aiSessionId String?
  aiSession   AISession? @relation(fields: [aiSessionId], references: [id], onDelete: SetNull)

  scheduledAt DateTime
  conductedAt DateTime?
  status      WelfareSessionStatus   @default(SCHEDULED)
  outcome     WelfareSessionOutcome?

  sessionNotes    String?
  concernDetails  String?
  escalationNotes String?
  actionItems     String?

  nextSessionDue DateTime?
  followUpNotes  String?

  durationMinutes Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([childId])
  @@index([conductedById])
  @@index([status])
  @@index([scheduledAt])
  @@index([nextSessionDue])
  @@index([childId, scheduledAt])
  @@map("welfare_sessions")
}

// ═══════════════════════════════════════════════════════════
// ── SECTION 17: NOTIFICATIONS & ALERTS
// ═══════════════════════════════════════════════════════════

model Notification {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type    NotificationType
  channel NotificationChannel @default(IN_APP)
  title   String
  body    String

  relatedEntityType String?
  relatedEntityId   String?

  isRead Boolean   @default(false)
  readAt DateTime?
  sentAt DateTime?

  deliveryStatus String?
  failureReason  String?
  retryCount     Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([isRead])
  @@index([type])
  @@index([createdAt])
  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@map("notifications")
}

model Alert {
  id String @id @default(uuid())

  severity AlertSeverity @default(MEDIUM)
  type     AlertType
  status   AlertStatus   @default(OPEN)
  title    String
  details  String?

  childId String?
  child   Child?  @relation("ChildAlerts", fields: [childId], references: [id], onDelete: SetNull)

  parentId String?
  parent   Parent? @relation("ParentAlerts", fields: [parentId], references: [id], onDelete: SetNull)

  orphanageId String?
  orphanage   Orphanage? @relation("OrphanageAlerts", fields: [orphanageId], references: [id], onDelete: SetNull)

  createdById  String?
  createdBy    User?   @relation("AlertCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  resolvedById String?
  resolvedBy   User?   @relation("AlertResolvedBy", fields: [resolvedById], references: [id], onDelete: SetNull)

  acknowledgedAt  DateTime?
  resolvedAt      DateTime?
  resolutionNotes String?

  isAutoGenerated Boolean @default(false)
  sourceService   String?

  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  riskScores AIRiskScore[]

  @@index([severity])
  @@index([type])
  @@index([status])
  @@index([childId])
  @@index([orphanageId])
  @@index([createdAt])
  @@index([status, severity])
  @@index([childId, status])
  @@map("alerts")
}

// ═══════════════════════════════════════════════════════════
// ── SECTION 18: AI SESSIONS & RISK SCORING
// ═══════════════════════════════════════════════════════════

model AISession {
  id String @id @default(uuid())

  sessionType AISessionType
  status      AISessionStatus @default(SCHEDULED)
  provider    AIProvider      @default(OPENAI_GPT4)

  childId String?
  child   Child?  @relation(fields: [childId], references: [id], onDelete: SetNull)

  initiatedById String?
  initiatedBy   User?   @relation("AISessionUser", fields: [initiatedById], references: [id], onDelete: SetNull)

  scheduledAt   DateTime?
  startedAt     DateTime?
  completedAt   DateTime?
  cancelledAt   DateTime?
  failureReason String?

  totalTokensUsed  Int?
  estimatedCostUsd Float?

  summary           String?
  riskLevelDetected RiskLevel?
  confidenceScore   Float?

  modelVersion  String?
  sessionConfig Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages        AIConversationMessage[]
  welfareSessions WelfareSession[]

  @@index([childId])
  @@index([initiatedById])
  @@index([sessionType])
  @@index([status])
  @@index([scheduledAt])
  @@map("ai_sessions")
}

model AIConversationMessage {
  id        String    @id @default(uuid())
  sessionId String
  session   AISession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  role     MessageRole
  content  String      @db.Text
  sequence Int

  promptTokens     Int?
  completionTokens Int?

  sentimentScore Float?
  detectedTopics Json?
  flaggedContent Boolean @default(false)
  flagReason     String?

  createdAt DateTime @default(now())

  @@unique([sessionId, sequence])
  @@index([sessionId])
  @@map("ai_conversation_messages")
}

model AIRiskScore {
  id      String @id @default(uuid())
  childId String
  child   Child  @relation(fields: [childId], references: [id], onDelete: Cascade)

  riskLevel RiskLevel
  score     Int

  attendanceScore Int?
  healthScore     Int?
  welfareScore    Int?
  guardianScore   Int?
  adoptionScore   Int?

  computedAt         DateTime @default(now())
  isComputedBySystem Boolean  @default(true)
  computedById       String?
  computedBy         User?    @relation("RiskScoreComputedBy", fields: [computedById], references: [id], onDelete: SetNull)
  modelVersion       String?
  notes              String?

  alertTriggered Boolean @default(false)
  alertId        String?
  alert          Alert?  @relation(fields: [alertId], references: [id], onDelete: SetNull)

  @@index([childId])
  @@index([riskLevel])
  @@index([computedAt])
  @@index([childId, computedAt])
  @@index([riskLevel, computedAt])
  @@map("ai_risk_scores")
}

// ═══════════════════════════════════════════════════════════
// ── SECTION 19: REPORTS & SYSTEM SETTINGS
// ═══════════════════════════════════════════════════════════

model ReportExport {
  id String @id @default(uuid())

  reportType ReportType
  format     ReportFormat @default(PDF)
  status     ReportStatus @default(QUEUED)

  requestedById String?
  requestedBy   User?   @relation("ReportRequestedBy", fields: [requestedById], references: [id], onDelete: SetNull)

  filters Json?

  fileName      String?
  storagePath   String?
  storageUrl    String?
  fileSizeBytes Int?

  queuedAt      DateTime  @default(now())
  startedAt     DateTime?
  completedAt   DateTime?
  expiresAt     DateTime?
  failureReason String?
  retryCount    Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([requestedById])
  @@index([reportType])
  @@index([status])
  @@index([createdAt])
  @@index([expiresAt])
  @@map("report_exports")
}

model SystemSetting {
  id String @id @default(uuid())

  key         String  @unique
  value       String  @db.Text
  dataType    String
  description String?
  group       String?
  isPublic    Boolean @default(false)

  updatedById String?
  updatedBy   User?   @relation("SettingUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([group])
  @@index([isPublic])
  @@map("system_settings")
}
