model Alert {
  id              String        @id @default(uuid())
  severity        AlertSeverity @default(MEDIUM)
  type            AlertType
  status          AlertStatus   @default(OPEN)
  title           String
  details         String?
  childId         String?
  parentId        String?
  orphanageId     String?
  createdById     String?
  resolvedById    String?
  acknowledgedAt  DateTime?
  resolvedAt      DateTime?
  resolutionNotes String?
  isAutoGenerated Boolean       @default(false)
  sourceService   String?
  metadata        Json?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  riskScores      AIRiskScore[]
  child           Child?        @relation("ChildAlerts", fields: [childId], references: [id])
  createdBy       User?         @relation("AlertCreatedBy", fields: [createdById], references: [id])
  orphanage       Orphanage?    @relation("OrphanageAlerts", fields: [orphanageId], references: [id])
  parent          Parent?       @relation("ParentAlerts", fields: [parentId], references: [id])
