generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                           String               @id @default(uuid())
  email                        String               @unique
  phone                        String?              @unique
  password                     String?
  provider                     AuthProvider         @default(LOCAL)
  providerUserId               String?
  firstName                    String
  lastName                     String
  avatar                       String?
  role                         Role                 @default(GUEST)
  isActive                     Boolean              @default(true)
  isEmailVerified              Boolean              @default(false)
  isPhoneVerified              Boolean              @default(false)
  isTwoFactorEnabled           Boolean              @default(false)
  twoFactorSecret              String?
  emailVerificationToken       String?              @unique
  emailVerificationTokenExpiry DateTime?
  passwordResetToken           String?              @unique
  passwordResetTokenExpiry     DateTime?
  loginAttempts                Int                  @default(0)
  lockedUntil                  DateTime?
  lastLoginAt                  DateTime?
  lastLoginIp                  String?
  passwordChangedAt            DateTime?
  createdAt                    DateTime             @default(now())
  updatedAt                    DateTime             @updatedAt
  deletedAt                    DateTime?
  reviewedAdoptions            AdoptionRecord[]     @relation("AdoptionReviewedBy")
  computedRiskScores           AIRiskScore[]        @relation("RiskScoreComputedBy")
  aiSessionsUser               AISession[]          @relation("AISessionUser")
  createdAlerts                Alert[]              @relation("AlertCreatedBy")
  resolvedAlerts               Alert[]              @relation("AlertResolvedBy")
  markedAttendance             AttendanceRecord[]   @relation("AttendanceMarkedBy")
  verifiedAttendance           AttendanceRecord[]   @relation("AttendanceVerifiedBy")
  auditLogs                    AuditLog[]           @relation("UserAuditLogs")
  capturedBiometrics           BiometricData[]      @relation("BiometricCapturedBy")
  uploadedChildDocs            ChildDocument[]      @relation("ChildDocumentUploadedBy")
  verifiedChildDocs            ChildDocument[]      @relation("ChildDocumentVerifiedBy")
  confirmedRelationships       ChildRelationship[]  @relation("RelationshipConfirmedBy")
  caseworkerChildren           Child[]              @relation("AssignedCaseworker")
  assignedChildren             Child[]              @relation("AssignedSocialWorker")
  recordedEducation            EducationRecord[]    @relation("EducationRecordedBy")
  recordedGuardians            GuardianHistory[]    @relation("GuardianRecordedBy")
  recordedHealthReps           HealthReport[]       @relation("HealthReportRecordedBy")
  recordedMedHistory           MedicalHistory[]     @relation("MedHistoryRecordedBy")
  notifications                Notification[]
  orphanageStaff               OrphanageStaff[]
  otpTokens                    OtpToken[]
  reviewedDocuments            ParentDocument[]     @relation("DocumentReviewedBy")
  parentProfile                Parent?
  verifiedParents              Parent[]             @relation("VerifiedBy")
  initiatedPoliceVer           PoliceVerification[] @relation("PoliceVerInitiatedBy")
  reviewedPoliceVer            PoliceVerification[] @relation("PoliceVerReviewedBy")
  refreshTokens                RefreshToken[]
  reportRequests               ReportExport[]       @relation("ReportRequestedBy")
  socialWorkerProfile          SocialWorkerProfile?
  systemSettings               SystemSetting[]      @relation("SettingUpdatedBy")
  performedTrustLogs           TrustScoreLog[]      @relation("TrustScorePerformedBy")
  reviewedVisitRequests        VisitRequest[]       @relation("VisitRequestReviewedBy")
  supervisedVisits             VisitRequest[]       @relation("VisitRequestSupervisor")
  conductedSessions            WelfareSession[]     @relation("SessionConductedBy")

  @@index([role])
  @@index([isActive])
  @@index([deletedAt])
  @@map("users")
}

model RefreshToken {
  id            String    @id @default(uuid())
  token         String    @unique
  jti           String    @unique
  userId        String
  userAgent     String?
  ipAddress     String?
  deviceId      String?
  isRevoked     Boolean   @default(false)
  revokedAt     DateTime?
  revokedReason String?
  expiresAt     DateTime
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isRevoked])
  @@index([isRevoked])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model OtpToken {
  id           String     @id @default(uuid())
  code         String
  purpose      OtpPurpose
  userId       String
  deliveredTo  String
  deliveryType String     @default("email")
  attempts     Int        @default(0)
  maxAttempts  Int        @default(5)
  isUsed       Boolean    @default(false)
  usedAt       DateTime?
  expiresAt    DateTime
  createdAt    DateTime   @default(now())
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([purpose])
  @@index([isUsed])
  @@index([expiresAt])
  @@index([userId, purpose])
  @@index([userId, purpose, isUsed])
  @@map("otp_tokens")
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?
  action     String
  resource   String?
  details    Json?
  ipAddress  String?
  userAgent  String?
  success    Boolean  @default(true)
  createdAt  DateTime @default(now())
  resourceId String?
  user       User?    @relation("UserAuditLogs", fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@index([resourceId])
  @@index([success])
  @@index([userId, createdAt])
  @@map("audit_logs")
}

model Orphanage {
  id                           String             @id @default(uuid())
  code                         String             @unique
  name                         String
  organizationType             OrganizationType
  status                       OrphanageStatus    @default(ACTIVE)
  registrationNumber           String             @unique
  governmentLicenseNumber      String?            @unique
  establishmentDate            DateTime?
  officialEmail                String             @unique
  phone                        String
  alternativePhone             String?
  website                      String?
  addressLine1                 String
  addressLine2                 String?
  landmark                     String?
  city                         String
  district                     String?
  state                        String
  pincode                      String
  country                      String             @default("India")
  latitude                     Float?
  longitude                    Float?
  totalCapacity                Int                @default(0)
  currentOccupancy             Int                @default(0)
  faceRecognitionEnabled       Boolean            @default(false)
  cctvInstalled                Boolean            @default(false)
  numberOfCameras              Int                @default(0)
  gpsTrackingAvailable         Boolean            @default(false)
  emergencyAlertEnabled        Boolean            @default(false)
  biometricAttendanceEnabled   Boolean            @default(false)
  bankName                     String?
  bankAccountNumber            String?
  bankIfscCode                 String?
  bankAccountHolder            String?
  complianceScore              Int                @default(0)
  lastInspectionDate           DateTime?
  nextInspectionDue            DateTime?
  isActive                     Boolean            @default(true)
  isVerified                   Boolean            @default(false)
  isFeatured                   Boolean            @default(false)
  gstNumber                    String?
  panNumber                    String?
  createdAt                    DateTime           @default(now())
  updatedAt                    DateTime           @updatedAt
  deletedAt                    DateTime?
  emergencyContactPerson       String?
  emergencyContactMobile       String?
  emergencyContactEmail        String?
  emergencyContactRelationship String?
  facilities                   Json?
  alerts                       Alert[]            @relation("OrphanageAlerts")
  children                     Child[]
  licenses                     OrphanageLicense[]
  staff                        OrphanageStaff[]
  visitRequests                VisitRequest[]

  @@index([status])
  @@index([state])
  @@index([city])
  @@index([isActive])
  @@index([isVerified])
  @@map("orphanages")
}

model OrphanageStaff {
  id          String             @id @default(uuid())
  orphanageId String
  userId      String
  role        OrphanageStaffRole @default(OTHER)
  designation String?
  employeeId  String?
  joiningDate DateTime?
  endDate     DateTime?
  isActive    Boolean            @default(true)
  notes       String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  orphanage   Orphanage          @relation(fields: [orphanageId], references: [id], onDelete: Cascade)
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([orphanageId, userId])
  @@index([orphanageId])
  @@index([userId])
  @@index([isActive])
  @@map("orphanage_staff")
}

model OrphanageLicense {
  id               String        @id @default(uuid())
  orphanageId      String
  licenseType      LicenseType
  licenseNumber    String
  issuingAuthority String
  status           LicenseStatus @default(PENDING)
  issuedDate       DateTime?
  expiryDate       DateTime?
  renewedDate      DateTime?
  documentUrl      String?
  storagePath      String?
  notes            String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  orphanage        Orphanage     @relation(fields: [orphanageId], references: [id], onDelete: Cascade)

  @@unique([orphanageId, licenseType])
  @@index([orphanageId])
  @@index([status])
  @@index([expiryDate])
  @@map("orphanage_licenses")
}

model Parent {
  id                       String                   @id @default(uuid())
  userId                   String                   @unique
  dateOfBirth              DateTime?
  nationality              String                   @default("Indian")
  religion                 String?
  maritalStatus            MaritalStatus?
  spouseName               String?
  spouseDateOfBirth        DateTime?
  spouseOccupation         String?
  alternatePhone           String?
  emergencyContact         String?
  emergencyContactName     String?
  emergencyContactRelation String?
  occupation               String?
  employmentType           EmploymentType?
  employerName             String?
  employerAddress          String?
  workPhone                String?
  yearsOfExperience        Int?
  annualIncome             Float?
  incomeRange              IncomeRange?
  incomeVerified           Boolean                  @default(false)
  numberOfRooms            Int?
  hasChildRoom             Boolean                  @default(false)
  hasChronicIllness        Boolean                  @default(false)
  chronicIllnessDetails    String?
  hasDisability            Boolean                  @default(false)
  disabilityDetails        String?
  hasHealthInsurance       Boolean                  @default(false)
  preferredChildAge        String?
  preferredCount           Int                      @default(1)
  openToSpecialNeeds       Boolean                  @default(false)
  specialNeedsDetails      String?
  adoptionMotivation       String?
  verificationStatus       ParentVerificationStatus @default(PENDING)
  verificationNotes        String?
  verifiedById             String?
  verifiedAt               DateTime?
  rejectionReason          String?
  interviewDate            DateTime?
  interviewNotes           String?
  interviewPassedAt        DateTime?
  trustScore               Int                      @default(0)
  trustScoreBreakdown      Json?
  lastTrustScoreUpdate     DateTime?
  kycSubmittedAt           DateTime?
  kycApprovedAt            DateTime?
  kycRejectionReason       String?
  isProfileComplete        Boolean                  @default(false)
  isActive                 Boolean                  @default(true)
  hasAdoptedBefore         Boolean                  @default(false)
  previousAdoptionDetails  String?
  isFeatured               Boolean                  @default(false)
  createdAt                DateTime                 @default(now())
  updatedAt                DateTime                 @updatedAt
  deletedAt                DateTime?
  gender                   Gender?
  houseOwnership           HouseOwnership?
  preferredGender          GenderPreference?
  kycStatus                KycStatus                @default(PENDING)
  adoptionRecords          AdoptionRecord[]
  alerts                   Alert[]                  @relation("ParentAlerts")
  caseAssignments          CaseAssignment[]
  familyMembers            FamilyMember[]
  guardianHistories        GuardianHistory[]        @relation("LinkedParent")
  addresses                ParentAddress[]
  documents                ParentDocument[]
  references               ParentReference[]
  user                     User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  verifiedBy               User?                    @relation("VerifiedBy", fields: [verifiedById], references: [id])
  policeVerification       PoliceVerification?
  trustScoreLogs           TrustScoreLog[]
  visitRequests            VisitRequest[]

  @@index([userId])
  @@index([verificationStatus])
  @@index([trustScore])
  @@index([kycStatus])
  @@index([isActive])
  @@index([deletedAt])
  @@map("parents")
}

model ParentReference {
  id         String    @id @default(uuid())
  parentId   String
  name       String
  phone      String
  relation   String
  email      String?
  occupation String?
  isVerified Boolean   @default(false)
  verifiedAt DateTime?
  notes      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  parent     Parent    @relation(fields: [parentId], references: [id], onDelete: Cascade)

  @@index([parentId])
  @@map("parent_references")
}

model ParentAddress {
  id           String      @id @default(uuid())
  parentId     String
  type         AddressType @default(CURRENT)
  addressLine1 String
  addressLine2 String?
  landmark     String?
  city         String
  district     String?
  state        String
  pincode      String
  country      String      @default("India")
  isVerified   Boolean     @default(false)
  verifiedAt   DateTime?
  isPrimary    Boolean     @default(false)
  latitude     Float?
  longitude    Float?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  parent       Parent      @relation(fields: [parentId], references: [id], onDelete: Cascade)

  @@index([parentId])
  @@index([type])
  @@index([isPrimary])
  @@map("parent_addresses")
}

model FamilyMember {
  id            String           @id @default(uuid())
  parentId      String
  name          String
  relationship  RelationshipType
  dateOfBirth   DateTime?
  occupation    String?
  annualIncome  Float?
  isDependent   Boolean          @default(false)
  contactPhone  String?
  notes         String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  aadhaarNumber String?
  gender        Gender?
  parent        Parent           @relation(fields: [parentId], references: [id], onDelete: Cascade)

  @@index([parentId])
  @@map("family_members")
}

model ParentDocument {
  id              String         @id @default(uuid())
  parentId        String
  documentType    DocumentType
  status          DocumentStatus @default(UPLOADED)
  fileName        String
  originalName    String
  mimeType        String
  fileSize        Int
  storagePath     String
  storageUrl      String?
  documentNumber  String?
  issuedBy        String?
  issuedDate      DateTime?
  expiryDate      DateTime?
  reviewedById    String?
  reviewedAt      DateTime?
  rejectionReason String?
  reviewNotes     String?
  isRequired      Boolean        @default(false)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  parent          Parent         @relation(fields: [parentId], references: [id], onDelete: Cascade)
  reviewedBy      User?          @relation("DocumentReviewedBy", fields: [reviewedById], references: [id])

  @@index([parentId])
  @@index([documentType])
  @@index([status])
  @@index([expiryDate])
  @@map("parent_documents")
}

model PoliceVerification {
  id                 String                   @id @default(uuid())
  parentId           String                   @unique
  status             PoliceVerificationStatus @default(NOT_INITIATED)
  applicationNumber  String?                  @unique
  appliedAt          DateTime?
  appliedStation     String?
  stationAddress     String?
  officerName        String?
  officerBadgeNumber String?
  officerPhone       String?
  clearedAt          DateTime?
  certificateNumber  String?
  certificateUrl     String?
  validUntil         DateTime?
  flagReason         String?
  flagDetails        String?
  crimeRecordFound   Boolean                  @default(false)
  crimeRecordDetails String?
  initiatedById      String?
  reviewedById       String?
  reviewNotes        String?
  lastFollowUpAt     DateTime?
  nextFollowUpAt     DateTime?
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  initiatedBy        User?                    @relation("PoliceVerInitiatedBy", fields: [initiatedById], references: [id])
  parent             Parent                   @relation(fields: [parentId], references: [id], onDelete: Cascade)
  reviewedBy         User?                    @relation("PoliceVerReviewedBy", fields: [reviewedById], references: [id])

  @@index([parentId])
  @@index([status])
  @@index([nextFollowUpAt])
  @@map("police_verifications")
}

model TrustScoreLog {
  id            String          @id @default(uuid())
  parentId      String
  event         TrustScoreEvent
  previousScore Int
  newScore      Int
  delta         Int
  reason        String?
  performedById String?
  metadata      Json?
  createdAt     DateTime        @default(now())
  parent        Parent          @relation(fields: [parentId], references: [id], onDelete: Cascade)
  performedBy   User?           @relation("TrustScorePerformedBy", fields: [performedById], references: [id])

  @@index([parentId])
  @@index([event])
  @@index([createdAt])
  @@index([parentId, createdAt])
  @@map("trust_score_logs")
}

model Child {
  id                      String              @id @default(uuid())
  childCode               String              @unique
  orphanageId             String?
  firstName               String
  lastName                String?
  dateOfBirth             DateTime?
  approximateAge          Int?
  gender                  ChildGender         @default(UNKNOWN)
  nationality             String              @default("Indian")
  religion                String?
  motherTongue            String?
  caste                   String?
  height                  Float?
  weight                  Float?
  bloodGroup              BloodGroup          @default(UNKNOWN)
  skinTone                String?
  eyeColor                String?
  hairColor               String?
  distinguishingMarks     String?
  aadhaarNumber           String?
  birthCertNumber         String?
  photo                   String?
  healthStatus            HealthStatus        @default(UNKNOWN)
  hasDisability           Boolean             @default(false)
  disabilityDetails       String?
  hasChronicCondition     Boolean             @default(false)
  chronicConditionDetails String?
  isVaccinationComplete   Boolean             @default(false)
  currentStatus           ChildStatus         @default(REGISTERED)
  adoptionStatus          AdoptionStatus      @default(NOT_INITIATED)
  isAdoptable             Boolean             @default(false)
  isActive                Boolean             @default(true)
  admissionDate           DateTime            @default(now())
  admissionReason         String?
  entrySource             String?
  referredBy              String?
  fatherName              String?
  motherName              String?
  familyBackground        String?
  foundLocation           String?
  foundDistrict           String?
  foundState              String?
  assignedSocialWorkerId  String?
  assignedCaseworkerId    String?
  specialNotes            String?
  internalNotes           String?
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt
  deletedAt               DateTime?
  fatherStatus            ParentStatus?
  motherStatus            ParentStatus?
  parentsMaritalStatus    MaritalStatus?
  adoptionRecord          AdoptionRecord?
  aiRiskScores            AIRiskScore[]
  aiSessions              AISession[]
  alerts                  Alert[]             @relation("ChildAlerts")
  attendanceRecords       AttendanceRecord[]
  biometricData           BiometricData[]
  caseAssignments         CaseAssignment[]
  documents               ChildDocument[]
  relationships           ChildRelationship[] @relation("ChildRelationships")
  relatedInRelationships  ChildRelationship[] @relation("RelatedChild")
  assignedCaseworker      User?               @relation("AssignedCaseworker", fields: [assignedCaseworkerId], references: [id])
  assignedSocialWorker    User?               @relation("AssignedSocialWorker", fields: [assignedSocialWorkerId], references: [id])
  orphanage               Orphanage?          @relation(fields: [orphanageId], references: [id])
  educationRecords        EducationRecord[]
  guardianHistories       GuardianHistory[]
  healthReports           HealthReport[]
  medicalHistories        MedicalHistory[]
  visitRequests           VisitRequest[]
  welfareSessions         WelfareSession[]

  @@index([childCode])
  @@index([orphanageId])
  @@index([currentStatus])
  @@index([adoptionStatus])
  @@index([healthStatus])
  @@index([isActive])
  @@index([isAdoptable])
  @@index([deletedAt])
  @@index([admissionDate])
  @@index([assignedSocialWorkerId])
  @@index([assignedCaseworkerId])
  @@index([orphanageId, isActive])
  @@index([orphanageId, currentStatus])
  @@map("children")
}

model MedicalHistory {
  id                 String                   @id @default(uuid())
  childId            String
  conditionName      String
  severity           MedicalConditionSeverity @default(MILD)
  diagnosedDate      DateTime?
  diagnosedBy        String?
  diagnosedAt        String?
  isCurrent          Boolean                  @default(true)
  isChronicCondition Boolean                  @default(false)
  treatmentDetails   String?
  medications        String?
  allergies          String?
  resolvedDate       DateTime?
  notes              String?
  recordedById       String?
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  child              Child                    @relation(fields: [childId], references: [id], onDelete: Cascade)
  recordedBy         User?                    @relation("MedHistoryRecordedBy", fields: [recordedById], references: [id])

  @@index([childId])
  @@index([isCurrent])
  @@index([severity])
  @@map("medical_histories")
}

model HealthReport {
  id                 String       @id @default(uuid())
  childId            String
  reportDate         DateTime
  reportedBy         String?
  facility           String?
  healthStatus       HealthStatus @default(HEALTHY)
  height             Float?
  weight             Float?
  bmi                Float?
  temperature        Float?
  bloodPressure      String?
  heartRate          Int?
  oxygenLevel        Float?
  findings           String?
  diagnosis          String?
  prescription       String?
  followUpDate       DateTime?
  followUpNotes      String?
  vaccinationGiven   String?
  vaccinationBatch   String?
  nextVaccinationDue DateTime?
  reportFileUrl      String?
  notes              String?
  recordedById       String?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  child              Child        @relation(fields: [childId], references: [id], onDelete: Cascade)
  recordedBy         User?        @relation("HealthReportRecordedBy", fields: [recordedById], references: [id])

  @@index([childId])
  @@index([reportDate])
  @@index([healthStatus])
  @@map("health_reports")
}

model AttendanceRecord {
  id                String           @id @default(uuid())
  childId           String
  date              DateTime
  status            AttendanceStatus @default(PRESENT)
  checkInTime       DateTime?
  checkOutTime      DateTime?
  activity          String?
  remarks           String?
  markedById        String?
  verifiedBy        String?
  isVerified        Boolean          @default(false)
  biometricVerified Boolean          @default(false)
  faceMatchScore    Float?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  verifiedById      String?
  child             Child            @relation(fields: [childId], references: [id], onDelete: Cascade)
  markedBy          User?            @relation("AttendanceMarkedBy", fields: [markedById], references: [id])
  verifiedByUser    User?            @relation("AttendanceVerifiedBy", fields: [verifiedById], references: [id])

  @@unique([childId, date, activity])
  @@index([childId])
  @@index([date])
  @@index([status])
  @@map("attendance_records")
}

model EducationRecord {
  id                     String         @id @default(uuid())
  childId                String
  level                  EducationLevel @default(NOT_ENROLLED)
  schoolName             String?
  schoolAddress          String?
  schoolBoard            String?
  className              String?
  section                String?
  rollNumber             String?
  academicYear           String?
  enrollmentDate         DateTime?
  completionDate         DateTime?
  isCurrent              Boolean        @default(true)
  attendancePercent      Float?
  lastGradePercent       Float?
  performanceNotes       String?
  teacherNotes           String?
  requiresSpecialSupport Boolean        @default(false)
  specialSupportDetails  String?
  hasScholarship         Boolean        @default(false)
  scholarshipDetails     String?
  recordedById           String?
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt
  child                  Child          @relation(fields: [childId], references: [id], onDelete: Cascade)
  recordedBy             User?          @relation("EducationRecordedBy", fields: [recordedById], references: [id])

  @@index([childId])
  @@index([isCurrent])
  @@map("education_records")
}

model GuardianHistory {
  id               String           @id @default(uuid())
  childId          String
  guardianName     String
  relation         GuardianRelation
  contactPhone     String?
  contactEmail     String?
  address          String?
  aadhaarNumber    String?
  isCurrent        Boolean          @default(false)
  startDate        DateTime
  endDate          DateTime?
  reasonForChange  String?
  handoverNotes    String?
  linkedParentId   String?
  courtOrderNumber String?
  courtOrderDate   DateTime?
  courtOrderUrl    String?
  recordedById     String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  child            Child            @relation(fields: [childId], references: [id], onDelete: Cascade)
  linkedParent     Parent?          @relation("LinkedParent", fields: [linkedParentId], references: [id])
  recordedBy       User?            @relation("GuardianRecordedBy", fields: [recordedById], references: [id])

  @@index([childId])
  @@index([isCurrent])
  @@index([linkedParentId])
  @@map("guardian_histories")
}

model BiometricData {
  id                  String        @id @default(uuid())
  childId             String
  type                BiometricType
  capturedAt          DateTime      @default(now())
  capturedBy          String?
  faceEncodingJson    String?
  faceImageUrl        String?
  faceModelVersion    String?
  fingerprintTemplate String?
  fingerprintFinger   String?
  templateData        String?
  deviceId            String?
  quality             Float?
  isActive            Boolean       @default(true)
  notes               String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  capturedByUser      User?         @relation("BiometricCapturedBy", fields: [capturedBy], references: [id])
  child               Child         @relation(fields: [childId], references: [id], onDelete: Cascade)

  @@index([childId])
  @@index([type])
  @@index([isActive])
  @@map("biometric_data")
}

model ChildDocument {
  id              String            @id @default(uuid())
  childId         String
  documentType    ChildDocumentType
  title           String
  fileName        String
  originalName    String
  mimeType        String
  fileSize        Int
  storagePath     String
  storageUrl      String?
  documentNumber  String?
  issuedBy        String?
  issuedDate      DateTime?
  expiryDate      DateTime?
  isVerified      Boolean           @default(false)
  verifiedById    String?
  verifiedAt      DateTime?
  rejectionReason String?
  notes           String?
