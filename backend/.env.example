# ============================================================
# Application
# ============================================================
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1
CORS_ORIGINS=http://localhost:5173,http://localhost:3001

# ============================================================
# Database (PostgreSQL via Prisma)
# ============================================================
DATABASE_URL=postgresql://postgres:om%40123@localhost:5432/child_safety_db?schema=public

# ============================================================
# JWT Configuration
# ============================================================
# Access token — short-lived (15 minutes recommended for prod)
JWT_ACCESS_SECRET=your-super-secret-access-token-key-change-in-production-min-32-chars
JWT_ACCESS_EXPIRY=15m

# Refresh token — long-lived (7 days recommended)
JWT_REFRESH_SECRET=your-super-secret-refresh-token-key-change-in-production-min-32-chars
JWT_REFRESH_EXPIRY=7d

# Email verification token expiry (24 hours)
EMAIL_VERIFICATION_EXPIRY_HOURS=24

# Password reset token expiry (1 hour)
PASSWORD_RESET_EXPIRY_HOURS=1

# ============================================================
# OTP Configuration
# ============================================================
OTP_EXPIRY_MINUTES=10
OTP_LENGTH=6
OTP_MAX_ATTEMPTS=5

# ============================================================
# Email (SMTP / Nodemailer)
# ============================================================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-specific-password
EMAIL_FROM_NAME=Child Safety System
EMAIL_FROM_ADDRESS=noreply@childsafety.org

# ============================================================
# Security
# ============================================================
BCRYPT_ROUNDS=12
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=30

# FIX-3, FIX-4: Encryption for sensitive data (bank, GST, PAN)
# CRITICAL: Must be at least 32 characters long
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_SECRET=change-this-to-a-secure-random-64-character-string-in-production-environment

# File uploads
UPLOAD_DIR=./uploads

# ============================================================
# Rate Limiting
# ============================================================
THROTTLE_SHORT_TTL=1000
THROTTLE_SHORT_LIMIT=3
THROTTLE_MEDIUM_TTL=10000
THROTTLE_MEDIUM_LIMIT=20
THROTTLE_LONG_TTL=60000
THROTTLE_LONG_LIMIT=100

# ============================================================
# Frontend URL (for email links)
# ============================================================
FRONTEND_URL=http://localhost:5173
