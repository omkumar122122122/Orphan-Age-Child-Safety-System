# Backend API base URL — MUST include the /api/v1 global prefix
# NestJS uses app.setGlobalPrefix('api/v1')
VITE_API_URL=http://localhost:3000/api/v1

# App Configuration
VITE_APP_NAME="Orphan Age Child Safety System"
VITE_APP_VERSION="1.0.0"
